#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="$HOME/.claude/claude-custom.json"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: Config file not found at $CONFIG_FILE"
    echo "Run the init skill to install."
    exit 1
fi

if [ -z "${OPENROUTER_API_KEY:-}" ]; then
    echo "Error: OPENROUTER_API_KEY environment variable is not set."
    exit 1
fi

# --- Parse arguments ---
MODEL=""
PROVIDER=""
PROFILE=""
PASSTHROUGH=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)     MODEL="$2";     shift 2 ;;
        --provider)  PROVIDER="$2";  shift 2 ;;
        --profile)   PROFILE="$2";   shift 2 ;;
        *)           PASSTHROUGH+=("$1"); shift ;;
    esac
done

# --- Resolve config inline (model only) ---
RESOLVED=$(PROFILE="$PROFILE" MODEL="$MODEL" python3 -c "
import json, os, sys
prof = os.environ.get('PROFILE', '')
model = os.environ.get('MODEL', '')
with open(os.path.expanduser('~/.claude/claude-custom.json')) as f:
    c = json.load(f)
if prof:
    p = c.get('profiles', {}).get(prof)
    if not p:
        print(f'Profile not found: {prof}', file=sys.stderr)
        sys.exit(1)
    model = model or p.get('model')
if not model:
    default = c.get('defaultProfile', 'default')
    def_prof = c.get('profiles', {}).get(default, {})
    model = def_prof.get('model')
if not model:
    print('Could not resolve model from config.', file=sys.stderr)
    sys.exit(1)
print(model)
" 2>&1) || { echo "$RESOLVED"; exit 1; }

if [ -z "$RESOLVED" ]; then
    echo "Error: Could not resolve model from config."
    exit 1
fi

# --- Set environment and launch ---
export ANTHROPIC_BASE_URL="https://openrouter.ai/api"
export ANTHROPIC_API_KEY="$OPENROUTER_API_KEY"
export ANTHROPIC_AUTH_TOKEN="$OPENROUTER_API_KEY"

claude --dangerously-skip-permissions --model "$RESOLVED" "${PASSTHROUGH[@]}"
