#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="$HOME/.claude"
CONFIG_FILE="$CONFIG_DIR/claude-custom.json"
PROXY_DIR="$CONFIG_DIR/claude-custom"
PROXY_BIN="$PROXY_DIR/OpenRouterProxy"

if [ ! -f "$PROXY_BIN" ]; then
    echo "Error: Proxy binary not found at $PROXY_BIN"
    echo "Run the init skill to install: claude --plugin-dir path/to/T.L-Claude-Code-Custom"
    exit 1
fi

if [ ! -x "$PROXY_BIN" ]; then
    chmod +x "$PROXY_BIN"
fi

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: Config file not found at $CONFIG_FILE"
    echo "Run the init skill to install."
    exit 1
fi

if [ -z "${OPENROUTER_API_KEY:-}" ]; then
    echo "Error: OPENROUTER_API_KEY environment variable is not set."
    exit 1
fi

MODEL=""
PROVIDER=""
PROFILE=""
PASSTHROUGH=""
IN_PASSTHROUGH=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --)
            IN_PASSTHROUGH=1
            shift
            ;;
        --model)
            MODEL="$2"
            shift 2
            ;;
        --provider)
            PROVIDER="$2"
            shift 2
            ;;
        --profile)
            PROFILE="$2"
            shift 2
            ;;
        *)
            if [[ "$IN_PASSTHROUGH" == "1" ]]; then
                PASSTHROUGH="$PASSTHROUGH $1"
            else
                echo "Unknown argument: $1"
                exit 1
            fi
            shift
            ;;
    esac
done

RESOLVED=$(python3 -c "
import json, sys
with open('$CONFIG_FILE') as f:
    c = json.load(f)
profile = '$PROFILE'
model = '$MODEL'
provider = '$PROVIDER'
if profile:
    prof = c.get('profiles', {}).get(profile)
    if not prof:
        print(f'Profile not found: {profile}', file=sys.stderr)
        sys.exit(1)
    model = model or prof.get('model')
    provider = provider or prof.get('provider')
if not model:
    default = c.get('defaultProfile', 'default')
    def_prof = c.get('profiles', {}).get(default, {})
    model = def_prof.get('model')
    provider = provider or def_prof.get('provider')
if not model:
    print('Could not resolve model from config.', file=sys.stderr)
    sys.exit(1)
print(f'{model}|{provider}')
" 2>&1) || { echo "$RESOLVED"; exit 1; }

RESOLVED_MODEL="${RESOLVED%%|*}"
RESOLVED_PROVIDER="${RESOLVED##*|}"

if [ -z "$RESOLVED_MODEL" ] || [ -z "$RESOLVED_PROVIDER" ]; then
    echo "Error: Could not resolve model/provider from config."
    exit 1
fi

PROXY_PORT=$(python3 -c "
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.bind(('127.0.0.1', 0))
print(s.getsockname()[1])
s.close()
")

PROXY_URL="http://127.0.0.1:${PROXY_PORT}"

"$PROXY_BIN" --urls "$PROXY_URL" &
PROXY_PID=$!

cleanup() {
    kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
}
trap cleanup EXIT

sleep 1

export ANTHROPIC_BASE_URL="$PROXY_URL"
export ANTHROPIC_AUTH_TOKEN="local"
export ANTHROPIC_API_KEY=""
export DEFAULT_PROVIDER="$RESOLVED_PROVIDER"

claude --model "$RESOLVED_MODEL"$PASSTHROUGH
